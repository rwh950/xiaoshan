# Hadoop NameNode WebHDFS地址
HDFS_URL=http://master:9870

# 以Hadoop用户身份访问
HDFS_USER=hadoop

# 第二周项目在HDFS中的根目录
HDFS_BASE=/user/hadoop/week02

# DataNode Web端口
DATANODE_WEB_PORT=9864

# Hadoop工作节点
HADOOP_WORKERS="slave1 slave2"

# HBase Thrift配置
HBASE_HOST=192.168.88.151
HBASE_PORT=9090
HBASE_TABLE=week02_user_stat
HBASE_FAMILY=cf
